<!DOCTYPE html>
<html lang="en">
<head>
{% include "partials/head.njk" %}
  <link rel="stylesheet" href="/assets/css/chat.css" />
</head>

<body>

  <div class="container">

    <!-- SIDEBAR -->
    <aside class="sidebar collapsed">

      <button
        class="mobile-toggle"
        onclick="toggleSidebar()"
        aria-label="Toggle Menu"
      >
        ☰ Menu
      </button>

      <!-- IDENTITY ZONE -->
      <div class="profile">

        <img
          src="/headshot.png"
          alt="Headshot of James Rodgers"
          class="avatar"
        />

        <h1>James D. Rodgers</h1>

        <p class="tagline-updated">
          Instructional Designer · Learning Systems Strategist · AI Integration Specialist
        </p>

        <p>
          Ask me anything about James's work, background, or learning design approach.
        </p>

        <h2 class="visually-hidden">How to Use This Assistant</h2>

        <ul>
          <li>Ask about James's background or instructional design approach</li>
          <li>Explore specific projects, tools, or design methods he uses</li>
          <li>Ask what kinds of roles or organizations are the best fit for his work</li>
        </ul>

      </div>

      <hr class="divider" />

      <!-- NAVIGATION -->
      <section class="nav-links-section">
        <h3>Explore</h3>
        <div class="nav-link-list">
          <a href="https://www.jamesdrodgers.ai/portfolio" class="nav-link-item">
            <span class="nav-link-icon">🗂️</span> Portfolio
          </a>
          <a href="https://www.jamesdrodgers.ai/resume" class="nav-link-item">
            <span class="nav-link-icon">📄</span> Resume
          </a>
          <a href="https://www.jamesdrodgers.ai/jamesrodgers" class="nav-link-item">
            <span class="nav-link-icon">👤</span> About Me
          </a>
        </div>
      </section>


      <hr class="divider" />

      <!-- CONTACT -->
      <div class="sidebar-contact">
        <button
          class="contact-btn-sidebar"
          onclick="showContactForm()"
          style="min-height:44px; width:100%;"
        >
          Contact James
        </button>
      </div>

    </aside>

    <!-- MAIN CHAT -->
    <main class="main-chat-area">

      <div class="chat-header">
        <h2 class="chat-title">Learn about my work.</h2>
        <button class="util-btn" onclick="clearChat()">Clear</button>
      </div>

      <!-- Welcome message -->
      <div class="welcome-message" id="welcomeMsg">
        <img
          src="/headshot.png"
          alt="James Rodgers"
          class="welcome-avatar"
        />
        <div class="welcome-text">
          Hi, I'm an AI trained on James's background. He's spent 15 years designing
          learning experiences — and the last two building and evaluating AI models at
          xAI. Ask about a specific project, how he thinks about AI in learning design,
          or whether he's a fit for a role you're hiring for.
        </div>
      </div>

      <!-- Suggestion chips -->
      <div class="suggestion-chips" id="chipContainer">
        <button class="chip" onclick="sendChip(this)">What did he work on at xAI?</button>
        <button class="chip" onclick="sendChip(this)">Tell me about the AI tutor he built for ICU nurses</button>
        <button class="chip" onclick="sendChip(this)">What's the swim science project?</button>
        <button class="chip" onclick="sendChip(this)">Is he open to full-time roles?</button>
      </div>

      <div id="chatContainer" class="chat-window"></div>

      <footer class="chat-input-area">
        <input
          id="userInput"
          type="text"
          placeholder="Ask a question about James's work…"
          autocomplete="off"
        />
        <button id="sendBtn">Send</button>
      </footer>

    </main>

  </div>

  <!-- CONTACT MODAL -->
  <div id="contactModal" class="modal">
    <div class="modal-content">
      <span class="close" onclick="closeContactForm()">&times;</span>
      <h2>Contact James</h2>
      <p>Send James a message and he'll get back to you soon.</p>
      <form id="contactForm" action="https://formspree.io/f/mrbrlydj" method="POST">
        <div class="form-group">
          <label>Your Name *</label>
          <input type="text" name="name" required />
        </div>
        <div class="form-group">
          <label>Your Email *</label>
          <input type="email" name="_replyto" required />
        </div>
        <div class="form-group">
          <label>Subject</label>
          <input type="text" name="_subject" value="Contact from jamesdrodgers.ai" />
        </div>
        <div class="form-group">
          <label>Message *</label>
          <textarea name="message" rows="5" required></textarea>
        </div>
        <div class="form-actions">
          <button type="button" class="btn-secondary" onclick="closeContactForm()">Cancel</button>
          <button type="submit" class="btn-primary">Send Message</button>
        </div>
      </form>
    </div>
  </div>

  <script src="/assets/js/chat.js"></script>
  <script>
    function sendChip(btn) {
      var text = btn.textContent.trim();
      document.getElementById('userInput').value = text;
      document.getElementById('chipContainer').style.display = 'none';
      document.getElementById('welcomeMsg').style.display = 'none';
      if (typeof sendMessage === 'function') sendMessage();
      else if (document.getElementById('sendBtn')) document.getElementById('sendBtn').click();
    }

    var origSend = document.getElementById('sendBtn');
    if (origSend) {
      origSend.addEventListener('click', function() {
        document.getElementById('chipContainer').style.display = 'none';
        document.getElementById('welcomeMsg').style.display = 'none';
      });
    }
    document.getElementById('userInput').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        document.getElementById('chipContainer').style.display = 'none';
        document.getElementById('welcomeMsg').style.display = 'none';
      }
    });
  </script>

</body>
</html>
